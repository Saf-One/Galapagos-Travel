// This is your Prisma schema file, used to define your database models.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // === CONFIGURABLE VALUES ===
  // SQLite for local dev/build (offline, self-contained). For production,
  // swap to Supabase Postgres: provider = "postgresql" and set DATABASE_URL
  // to your Supabase connection string (e.g. postgresql://user:pass@host:5432/postgres).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- NextAuth (Auth.js) adapter models ---
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  accounts     Account[]
  sessions     Session[]
  bookings     Booking[]
  invoices     Invoice[]
  loyaltyPoints LoyaltyPoint[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain models ---
model Package {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String
  summary       String
  description   String
  priceInCents  Int
  currency      String          @default("USD")
  durationDays  Int
  location      String
  maxGuests     Int
  featured      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  images        PackageImage[]
  bookings      Booking[]

  @@index([slug])
  @@index([featured])
}

model PackageImage {
  id        String  @id @default(cuid())
  packageId String
  url       String
  alt       String
  sortOrder Int     @default(0)
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model Promotion {
  id              String   @id @default(cuid())
  code            String   @unique
  label           String
  discountPercent Int
  startDate       DateTime
  endDate         DateTime
  active          Boolean  @default(true)

  @@index([code])
}

model Booking {
  id              String         @id @default(cuid())
  reference       String         @unique
  userId          String?
  packageId       String
  startDate       DateTime
  guests          Int
  status          BookingStatus  @default(PENDING)
  totalCents      Int
  currency        String         @default("USD")
  paymentProvider PaymentProvider @default(NONE)
  paymentId       String?
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  package         Package        @relation(fields: [packageId], references: [id], onDelete: Cascade)
  invoices        Invoice[]

  @@index([reference])
  @@index([userId])
  @@index([packageId])
}

model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique
  bookingId  String
  userId     String
  amountCents Int
  currency   String        @default("USD")
  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime?
  pdfUrl     String?
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([number])
  @@index([bookingId])
  @@index([userId])
}

model LoyaltyPoint {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Lead {
  id             String   @id @default(cuid())
  email          String
  name           String?
  source         String?
  payload        String // JSON string (SQLite has no native JSON type)
  createdAt      DateTime @default(now())
  syncedToHubspot Boolean @default(false)

  @@index([email])
}

// --- Enums ---
enum Role {
  CUSTOMER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  NONE
  STRIPE
  PAYPAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  REFUNDED
}
