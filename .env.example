# ============================================================
# Galapagos Travel - Environment Variables (example)
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# Every value has a fallback in code so the app builds offline.
# ============================================================

# --- Database (SQLite for local dev/build; swap to Supabase Postgres in prod) ---
# Local SQLite file (relative to project root where prisma runs).
DATABASE_URL="file:./dev.db"
# Production example (commented): postgresql://user:pass@host:5432/galapagos?schema=public

# --- Site / Contact ---
SITE_NAME="Galapagos Voyages"
CONTACT_EMAIL="hello@galapagos.example"
SITE_URL="http://localhost:3000"

# --- i18n ---
DEFAULT_LOCALE="en"
# Comma-separated list mirrors next-intl locales: en,es,zh

# --- Auth (NextAuth / Auth.js v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-insecure-secret-change-me-in-production-please-32chars"
# Public base URL used by NextAuth callbacks.
NEXTAUTH_URL="http://localhost:3000"

# --- Payments (Stripe) ---
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# --- Payments (PayPal) ---
PAYPAL_CLIENT_ID="placeholder"
PAYPAL_CLIENT_SECRET="placeholder"
# Use "live" for production, "sandbox" for testing.
PAYPAL_MODE="sandbox"

# --- HubSpot (CRM lead sync) ---
HUBSPOT_API_KEY=""
HUBSPOT_PORTAL_ID=""

# --- Analytics (Google Analytics 4) ---
# Leave empty to disable GA rendering in the layout.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# --- Chatbot / Messaging (contact links) ---
WHATSAPP_NUMBER="593999999999"
WECHAT_ID="galapagos_voyages"
